generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  First_name    String
  Last_Name     String
  Username      String   @unique
  Password      String
  Salt          String
  Email_address String   @unique
  Is_Youtuber   Boolean
  Is_Pro        Boolean
  Role          UserRole @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// TODO : utiliser les enum avec la mtehode prisma orm
enum UserRole {
  USER
  ADMIN
}
